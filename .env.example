# ---- CareLoop environment ----
# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# ASI:One LLM (https://asi1.ai/dashboard/api-keys). Promo code: BERKELEYAI
ASI1_API_KEY=

# Agentverse API key (Agentverse -> Profile -> API Keys). Promo code: BERKELEYAIAV
AGENTVERSE_API_KEY=

# Deepgram (https://console.deepgram.com). Used for STT + TTS in the voice app.
DEEPGRAM_API_KEY=

# Optional: Anthropic key to run the triage agent on Claude for clinical-reasoning quality.
# If empty, triage falls back to ASI:One. (Anthropic prize is also covered by "built with Claude Code".)
ANTHROPIC_API_KEY=

# ---- Inter-agent wiring (filled in after first run / mailbox registration) ----
# Each agent prints its address on startup; paste the specialist addresses here so the
# orchestrator can route to them. (run scripts/print_addresses.py to get them deterministically.)
TRIAGE_AGENT_ADDRESS=
PROVIDER_AGENT_ADDRESS=
COST_AGENT_ADDRESS=
SCHEDULER_AGENT_ADDRESS=

# ---- Ports (local) ----
ORCHESTRATOR_PORT=8000
TRIAGE_PORT=8001
PROVIDER_PORT=8002
COST_PORT=8003
SCHEDULER_PORT=8004
VOICE_BACKEND_PORT=8080

# Orchestrator REST endpoint the voice backend calls
ORCHESTRATOR_REST_URL=http://127.0.0.1:8000/voice

# ---- Optional model tuning (sensible defaults baked in) ----
ASI1_MODEL=asi1-mini                 # asi1-mini | asi1-fast | asi1-extended
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
DEEPGRAM_STT_LANG=multi              # Nova-3 multilingual code-switching; or en, es, zh, hi, fr
